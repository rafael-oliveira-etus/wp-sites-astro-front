---
import {
  type SeoProps,
  buildOrganizationSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
  inferImageType,
} from '../lib/seo';
import { TENANT, localeDisplay } from '../lib/tenant';
import { absoluteUrl, bcp47ToOgLocale } from '../lib/url';
import AnalyticsBoot from './AnalyticsBoot.astro';
import { AD_PRECONNECT_ORIGINS } from '@etus/ads';
import type { Vertical } from '../lib/schemas';

type Props = SeoProps & {
  locale: string;
  vertical?: Vertical | null;
  analytics?: boolean;
  themeColor?: string;
  /** Absolute favicon URL from the headless CMS (BOLT branding). The only favicon
   *  source — no local fallback. When absent, no icon link is emitted. */
  faviconUrl?: string;
};

const {
  locale,
  vertical = null,
  analytics = true,
  themeColor = TENANT.brand.primaryColor,
  faviconUrl,
  title,
  description,
  image,
  imageAlt,
  imageType,
  type = 'website',
  canonical,
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
  keywords,
  schemas = [],
  alternates = [],
} = Astro.props;

const display = localeDisplay(TENANT, locale);
// D-5: preconnect the GPT host so the first ad request skips DNS/TLS. Gated on the
// tenant having ads configured (dormant until Phase E wires gpt.js) so we don't
// open an unused connection on ad-free tenants.
const adsEnabled = !!TENANT.ads;

const fullTitle = !title || title === display.siteName
  ? display.siteName
  : `${title} | ${display.siteName}`;

const finalDescription = description ?? display.description;
const canonicalUrl = canonical ?? absoluteUrl(TENANT, Astro.url.pathname);
// `image` comes from WordPress (yoast.ogImage / featured media) and is absolute.
// No local fallback: when WP gives us no image we emit no og/twitter image tag.
const imageUrl = image
  ? (/^https?:\/\//.test(image) ? image : absoluteUrl(TENANT, image))
  : undefined;
const resolvedImageType = image ? (imageType ?? inferImageType(image)) : undefined;
const finalImageAlt = imageAlt ?? display.siteName;

// Headless tenants get their favicon from the CMS (BOLT branding). Strip any
// query string (WP appends ?w=… to media URLs) before inferring the MIME type.
const faviconType = faviconUrl ? inferImageType(faviconUrl.split('?')[0]) : null;

const robotsValue = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const defaultSchemas = [
  buildOrganizationSchema(TENANT),
  buildWebSiteSchema(TENANT, locale),
  buildWebPageSchema(TENANT, locale, {
    title: fullTitle,
    description: finalDescription,
    url: canonicalUrl,
    image: imageUrl,
  }),
];

const allSchemas = [...defaultSchemas, ...schemas];

const hreflangSelf = { hreflang: locale, href: canonicalUrl };
const hreflangAll = [hreflangSelf, ...alternates];
const xDefaultHref = alternates.find((a) => a.hreflang === TENANT.defaultLocale)?.href
  ?? canonicalUrl;

// T1.5.H14 — `og:locale:alternate` — emit one tag per alternate locale (not
// the current one). FB/LinkedIn use this to surface the correct localized
// preview when the same OG URL is shared in different locales.
const ogAlternateLocales = alternates
  .filter((a) => a.hreflang !== locale)
  .map((a) => bcp47ToOgLocale(a.hreflang));

// T1.5.H16 — Preconnect to origins used on the critical request path. Saves
// ~150ms TLS+DNS on mobile cold connections. Skips when the events-api is
// same-origin (empty tracking.eventsApiUrl) — there's nothing extra to
// preconnect to. Turnstile script lives at challenges.cloudflare.com, only
// loaded when the tenant has the widget enabled.
const eventsApiOrigin = (() => {
  try {
    const raw =
      (import.meta.env.PUBLIC_EVENTS_API_URL as string | undefined) ||
      TENANT.tracking.eventsApiUrl ||
      '';
    if (!raw) return null;
    const u = new URL(raw);
    return u.origin === Astro.url.origin ? null : u.origin;
  } catch { return null; }
})();
const turnstileEnabled =
  TENANT.tracking.turnstile?.enabled && TENANT.tracking.turnstile?.siteKey;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta http-equiv="x-ua-compatible" content="ie=edge" />

{analytics && <AnalyticsBoot locale={locale} vertical={vertical} />}

<title>{fullTitle}</title>
<meta name="description" content={finalDescription} />
{author && <meta name="author" content={author} />}
{keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

<meta name="robots" content={robotsValue} />
<meta name="googlebot" content={robotsValue} />

<meta name="theme-color" content={themeColor} />
<meta name="color-scheme" content="light dark" />
<!-- T2.24 — `format-detection: telephone=no` removed. We have a legit
     "Call us" link path in some footer disclosures, and blocking detection
     globally breaks Safari/iOS smart phone-number recognition. Disable
     locally on inputs where it actually causes layout shift. -->

<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="generator" content={Astro.generator} />

{eventsApiOrigin && (
  <link rel="preconnect" href={eventsApiOrigin} crossorigin />
)}
{turnstileEnabled && (
  <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin />
)}
{adsEnabled && (
  <link rel="preconnect" href={AD_PRECONNECT_ORIGINS[0]} crossorigin />
)}
{TENANT.blog?.wpBaseUrl && (
  <link rel="preconnect" href="https://media.limitemais.com" crossorigin />
)}

<link rel="canonical" href={canonicalUrl} />
{hreflangAll.map((alt) => (
  <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={display.siteName} />
<meta property="og:locale" content={bcp47ToOgLocale(locale)} />
{ogAlternateLocales.map((og) => (
  <meta property="og:locale:alternate" content={og} />
))}
{imageUrl && (
  <Fragment>
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:type" content={resolvedImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={finalImageAlt} />
  </Fragment>
)}
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{author && type === 'article' && <meta property="article:author" content={author} />}

<meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
<meta name="twitter:site" content={TENANT.seo.twitterHandle} />
<meta name="twitter:creator" content={TENANT.seo.twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={finalDescription} />
{imageUrl && (
  <Fragment>
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={finalImageAlt} />
  </Fragment>
)}

{faviconUrl && (
  <Fragment>
    <link rel="icon" href={faviconUrl} type={faviconType} transition:persist="head-icon" />
    <link rel="apple-touch-icon" href={faviconUrl} sizes="180x180" transition:persist="head-apple-touch-icon" />
  </Fragment>
)}
<link rel="sitemap" href="/sitemap-index.xml" transition:persist="head-sitemap" />

{/* Structured data (JSON-LD) temporarily DISABLED for headless-WP tenants —
    those pages have no SEO focus yet (user request 2026-06-17). Quiz/SSG
    tenants keep it. Re-enable by removing the `!wpBaseUrl` guard below.
    T2.26 — single `@graph` (cuts weight, avoids repeated @context, and one
    malformed sub-schema can't invalidate the whole batch). */}
{!TENANT.blog?.wpBaseUrl && (
  <script
    type="application/ld+json"
    is:inline
    nonce={Astro.locals.nonce}
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': allSchemas.map((s) => {
        // Strip nested @context — the wrapping @graph supplies it.
        const { '@context': _ctx, ...rest } = s;
        return rest;
      }),
    })}
  />
)}

{
  TENANT.tracking.turnstile?.enabled && TENANT.tracking.turnstile?.siteKey && (
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
      async
      defer
      nonce={Astro.locals.nonce}
      transition:persist="turnstile-loader"
    />
  )
}
