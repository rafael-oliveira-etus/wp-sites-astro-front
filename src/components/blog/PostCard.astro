---
import type { CollectionEntry } from 'astro:content';
import { postMeta } from '../../lib/content';
import { postPath } from '../../lib/url';

interface Props {
  post: CollectionEntry<'post'>;
  locale: string;
  verticalLabel: string;
  minReadLabel: string;
}
const { post, locale, verticalLabel, minReadLabel } = Astro.props;
const meta = postMeta(post);
---

<li class="post-card">
  <a href={postPath(locale, meta.vertical, meta.slug)}>
    <span class="post-vertical">{verticalLabel}</span>
    <h2>{post.data.title}</h2>
    <p>{post.data.description}</p>
    <span class="post-card-meta">
      {post.data.readingTimeMinutes} {minReadLabel} · {post.data.publishedAt.toLocaleDateString(locale)}
    </span>
  </a>
</li>

<style>
  .post-card {
    list-style: none;
  }

  .post-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-fg) 8%, transparent);
    text-decoration: none;
    color: inherit;
  }

  .post-card a:hover {
    border-color: var(--color-primary);
  }

  .post-vertical {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .post-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .post-card p {
    margin: 0 0 1rem;
    color: var(--color-muted);
    font-size: 0.9375rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    margin-top: auto;
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>
