---
// Social share row + copy-link. Share hrefs are built at build time (no JS for
// the network links — plain anchors). Copy-link is a tiny inline island.
interface Props {
  url: string;
  title: string;
  shareLabel: string;
  copyLabel: string;
  copiedLabel: string;
}
const { url, title, shareLabel, copyLabel, copiedLabel } = Astro.props;
const u = encodeURIComponent(url);
const t = encodeURIComponent(title);
const networks = [
  { name: 'X', href: `https://twitter.com/intent/tweet?url=${u}&text=${t}` },
  { name: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${u}` },
  { name: 'LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${u}` },
  { name: 'WhatsApp', href: `https://api.whatsapp.com/send?text=${t}%20${u}` },
];
---

<div class="share-bar" aria-label={shareLabel}>
  <span class="share-label">{shareLabel}</span>
  <ul>
    {networks.map((n) => (
      <li>
        <a
          href={n.href}
          target="_blank"
          rel="noopener noreferrer nofollow"
          aria-label={`${shareLabel} — ${n.name}`}
        >{n.name}</a>
      </li>
    ))}
    <li>
      <button
        type="button"
        class="copy-link"
        data-url={url}
        data-copy={copyLabel}
        data-copied={copiedLabel}
        aria-label={copyLabel}
      >{copyLabel}</button>
    </li>
  </ul>
</div>

<script is:inline data-astro-rerun>
  // Delegated on document so it works regardless of when the button mounts or
  // is swapped (ClientRouter view transitions). Feedback is optimistic — shown
  // immediately on click — because the clipboard write can hang/reject under
  // automation or without transient activation, and the UI shouldn't depend on
  // it. Bind-once guard since data-astro-rerun re-runs this script per nav.
  (function () {
    if (window.__shareCopyBound) return;
    window.__shareCopyBound = true;
    document.addEventListener('click', function (e) {
      var btn = e.target && e.target.closest ? e.target.closest('button.copy-link') : null;
      if (!btn) return;
      var url = btn.getAttribute('data-url') || location.href;
      var copied = btn.getAttribute('data-copied') || 'Copied';
      var original = btn.getAttribute('data-copy') || 'Copy link';
      btn.textContent = copied;
      setTimeout(function () { btn.textContent = original; }, 2000);
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).catch(function () {});
      }
    });
  })();
</script>

<style>
  .share-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin: 2.5rem 0;
    padding: 1rem 0;
    border-top: 1px solid color-mix(in srgb, var(--color-fg) 8%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-fg) 8%, transparent);
  }

  .share-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .share-bar ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .share-bar a,
  .copy-link {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-fg) 12%, transparent);
    background: transparent;
    color: var(--color-fg);
    font: inherit;
    font-size: 0.8125rem;
    text-decoration: none;
    cursor: pointer;
  }

  .share-bar a:hover,
  .copy-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
</style>
