---
import type { CollectionEntry } from 'astro:content';
import { postMeta } from '../../lib/content';
import { postPath } from '../../lib/url';

interface Props {
  posts: CollectionEntry<'post'>[];
  locale: string;
  heading: string;
}
const { posts, locale, heading } = Astro.props;
---

{posts.length > 0 && (
  <section class="related">
    <h2>{heading}</h2>
    <ul>
      {posts.map((rp) => {
        const m = postMeta(rp);
        return (
          <li>
            <a href={postPath(locale, m.vertical, m.slug)}>
              <h3>{rp.data.title}</h3>
              <p>{rp.data.description}</p>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}

<style>
  .related {
    padding: 3rem 0 0;
    border-top: 1px solid color-mix(in srgb, var(--color-fg) 8%, transparent);
    margin-top: 3rem;
  }

  .related h2 {
    margin: 0 0 1.5rem;
    font-size: 1.5rem;
  }

  .related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
  }

  .related a {
    display: block;
    padding: 1rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-fg) 8%, transparent);
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .related a:hover {
    border-color: var(--color-primary);
  }

  .related h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    line-height: 1.3;
  }

  .related p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.875rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
