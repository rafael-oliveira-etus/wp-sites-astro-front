---
import type { PostHeading } from '../../lib/markdown';

interface Props {
  headings: PostHeading[];
  title: string;
}
const { headings, title } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <p class="toc-title">{title}</p>
  <ul>
    {headings.map((h) => (
      <li class={h.depth === 3 ? 'sub' : ''}>
        <a href={`#${h.id}`} data-toc-link={h.id}>{h.text}</a>
      </li>
    ))}
  </ul>
</nav>

<script is:inline nonce={Astro.locals.nonce} data-astro-rerun>
  (function () {
    function init() {
      var links = Array.prototype.slice.call(
        document.querySelectorAll('a[data-toc-link]'),
      );
      if (!links.length || !('IntersectionObserver' in window)) return;
      var byId = {};
      links.forEach(function (a) { byId[a.getAttribute('data-toc-link')] = a; });
      var targets = links
        .map(function (a) { return document.getElementById(a.getAttribute('data-toc-link')); })
        .filter(Boolean);
      if (!targets.length) return;
      var current = null;
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              if (current) current.classList.remove('active');
              var a = byId[e.target.id];
              if (a) { a.classList.add('active'); current = a; }
            }
          });
        },
        { rootMargin: '0px 0px -75% 0px', threshold: 0 },
      );
      targets.forEach(function (t) { io.observe(t); });
    }
    // The editorial theme renders the TOC BEFORE the article in the DOM, so the
    // heading targets don't exist when this inline script first runs. Defer to
    // DOMContentLoaded while the document is still parsing (on view-transition
    // re-runs the doc is already complete → init runs immediately).
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .toc {
    font-size: 0.875rem;
  }

  .toc-title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }

  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
  }

  .toc li {
    margin: 0;
  }

  .toc li.sub a {
    padding-left: 1.75rem;
    font-size: 0.8125rem;
  }

  .toc a {
    display: block;
    padding: 0.3rem 0 0.3rem 1rem;
    margin-left: -2px;
    border-left: 2px solid transparent;
    color: var(--color-muted);
    text-decoration: none;
    line-height: 1.35;
  }

  .toc a:hover {
    color: var(--color-fg);
  }

  .toc a.active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .toc a {
      transition: color 0.15s ease, border-color 0.15s ease;
    }
  }
</style>
