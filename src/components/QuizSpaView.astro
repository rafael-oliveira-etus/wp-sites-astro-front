---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import TurnstileWidget from './TurnstileWidget.astro';
import { TENANT, localeDisplay } from '../lib/tenant';
import { quizPath, absoluteUrl } from '../lib/url';
import { buildQuizSchema } from '../lib/seo';
import { resolveRedirect } from '../lib/redirect';
import type { Quiz, Vertical } from '../lib/schemas';

interface Props {
  locale: string;
  vertical: Vertical;
  slug: string;
  quiz: Quiz;
}

const { locale, vertical, slug, quiz } = Astro.props;

const display = localeDisplay(TENANT, locale);
const stepIds = quiz.steps.map((s) => s.id);
const hasCapture = Boolean(quiz.capture);
const totalScreens = stepIds.length + (hasCapture ? 1 : 0) + 1;
const firstStepId = stepIds[0];

const redirect = await resolveRedirect(quiz, locale, vertical);
const redirectRuntimeJson = JSON.stringify(redirect.runtime);

const canonical = absoluteUrl(TENANT, quizPath(locale, vertical, slug));
const alternates = Object.entries(quiz.equivalents).map(([altLocale, altSlug]) => ({
  hreflang: altLocale,
  href: absoluteUrl(TENANT, quizPath(altLocale, vertical, altSlug)),
}));

const seoSchemas = [
  buildQuizSchema(TENANT, locale, {
    title: quiz.title,
    description: quiz.description,
    url: canonical,
    numberOfQuestions: quiz.steps.length,
  }),
];

const quizBase = {
  quiz_slug: quiz.slug,
  vertical: quiz.vertical,
  mode: quiz.mode,
  total_steps: totalScreens,
  total_questions: stepIds.length,
  has_capture: hasCapture,
};

const captureFieldsShown = quiz.capture
  ? Object.entries(quiz.capture.fields)
      .filter(([, v]) => v.enabled)
      .map(([k]) => k)
  : [];

const quizBaseJson = JSON.stringify(quizBase);
const captureFieldsJson = JSON.stringify(captureFieldsShown);
---

<BaseLayout
  locale={locale}
  vertical={vertical}
  title={quiz.seoTitle ?? quiz.title}
  description={quiz.description}
  canonical={canonical}
  schemas={seoSchemas}
  alternates={alternates}
  transitions={false}
>
  <Fragment slot="head">
    {redirect.prefetchHrefs
      .filter((h) => h.startsWith('/'))
      .map((href) => (
        <link rel="prefetch" href={href} as="document" />
      ))}
  </Fragment>
  <Header locale={locale} variant="minimal" />
  <noscript>
    <p class="noscript-msg">{display.noscript.quiz}</p>
  </noscript>
  <main
    id="main"
    class="quiz-shell"
    data-spa-quiz
    data-first-step={firstStepId}
    data-has-capture={hasCapture ? '1' : '0'}
    data-total-screens={totalScreens}
    data-redirect-runtime={redirectRuntimeJson}
    data-noscript-href={redirect.noscriptHref}
    data-quiz-base={quizBaseJson}
    data-capture-fields={captureFieldsJson}
    data-quiz-slug={quiz.slug}
    data-quiz-vertical={quiz.vertical}
    data-quiz-mode={quiz.mode}
  >
    <div class="quiz-topbar">
      <button
        type="button"
        class="back-btn"
        data-spa-back
        aria-label={display.ui.back}
        hidden
      >
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
          <path
            d="M10 13L5 8l5-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span>{display.ui.back}</span>
      </button>
      <div class="progress" aria-label={display.ui.progressAria}>
        <div class="progress-bar"></div>
        <span class="progress-label" data-progress-label></span>
      </div>
    </div>

    <div class="screens">
      {quiz.steps.map((s, idx) => (
        <section
          class:list={['screen', 'step', 'question', { active: idx === 0 }]}
          data-screen={s.id}
          style={idx === 0 ? undefined : 'display:none'}
        >
          {idx === 0 && (
            <header class="landing-intro">
              <h1>{quiz.title}</h1>
              <p class="lede">{quiz.description}</p>
            </header>
          )}
          <h2>{s.question}</h2>
          <ul class="options" data-step-id={s.id}>
            {s.options.map((opt) => (
              <li>
                <button type="button" data-value={opt.value} data-next={opt.next ?? ''}>
                  {opt.label}
                </button>
              </li>
            ))}
          </ul>
        </section>
      ))}

      {quiz.capture && (
        <section class="screen step capture" data-screen="capture" style="display:none">
          <h1>{quiz.capture.headline}</h1>
          <p class="lede">{quiz.capture.subheadline}</p>
          <form id="capture-form" novalidate>
            {quiz.capture.fields.name.enabled && (
              <label class="field">
                <span>{quiz.capture.fields.name.label}</span>
                <input
                  type="text"
                  name="name"
                  placeholder={quiz.capture.fields.name.placeholder}
                  required={quiz.capture.fields.name.required}
                  autocomplete="given-name"
                />
              </label>
            )}
            {quiz.capture.fields.email.enabled && (
              <label class="field">
                <span>{quiz.capture.fields.email.label}</span>
                <input
                  type="email"
                  name="email"
                  placeholder={quiz.capture.fields.email.placeholder}
                  required={quiz.capture.fields.email.required}
                  autocomplete="email"
                />
              </label>
            )}
            {quiz.capture.fields.phone.enabled && (
              <label class="field">
                <span>{quiz.capture.fields.phone.label}</span>
                <input
                  type="tel"
                  name="phone"
                  placeholder={quiz.capture.fields.phone.placeholder}
                  required={quiz.capture.fields.phone.required}
                  autocomplete="tel"
                />
              </label>
            )}
            <label class="consent">
              <input type="checkbox" name="consent" required />
              <span>{display.legalConsent}</span>
            </label>
            {/* Honeypot (T0.10) — off-screen + untabbable; bots auto-fill. */}
            <input
              type="text"
              name="website"
              class="honeypot"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <TurnstileWidget />
            <button class="submit" type="submit">{quiz.capture.submitLabel}</button>
            <p class="privacy">{quiz.capture.privacyNote}</p>
          </form>
        </section>
      )}

      <section class="screen step processing" data-screen="processing" style="display:none">
        <div class="spinner" aria-hidden="true"></div>
        <h1>{display.tagline}</h1>
        <p class="lede">{display.description}</p>
        <p class="redirect-note">
          <a href={redirect.noscriptHref}>{display.ui.continueLabel} →</a>
        </p>
      </section>
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-spa-quiz]');
    if (!root) return;
    var totalScreens = Number(root.dataset.totalScreens || '1');
    var hasCapture = root.dataset.hasCapture === '1';
    var fallbackResult = root.dataset.noscriptHref || '';
    var runtimeRaw = root.dataset.redirectRuntime || '';
    var firstStepId = root.dataset.firstStep || '';
    var quizBase = {};
    var captureFields = [];
    try { quizBase = JSON.parse(root.dataset.quizBase || '{}'); } catch (_) {}
    try { captureFields = JSON.parse(root.dataset.captureFields || '[]'); } catch (_) {}
    var progressBar = root.querySelector('.progress-bar');
    var progressLabel = root.querySelector('[data-progress-label]');
    var backBtn = root.querySelector('[data-spa-back]');
    var screens = Array.prototype.slice.call(root.querySelectorAll('[data-screen]'));
    var historyStack = [];
    var stepEnteredAt = Date.now();
    var formEnteredAt = 0;
    var quizStartedAt = Date.now();
    screens.forEach(function (el) { el.style.removeProperty('display'); });
    root.classList.add('js-ready');

    function track(name, extra) {
      if (!window.etus || !window.etus.track) return null;
      var payload = {};
      for (var k in quizBase) payload[k] = quizBase[k];
      if (extra) for (var k2 in extra) payload[k2] = extra[k2];
      return window.etus.track(name, payload);
    }

    function indexOfStep(id) {
      for (var i = 0; i < stepIds.length; i++) if (stepIds[i] === id) return i;
      return -1;
    }
    var stepIds = screens
      .map(function (s) { return s.dataset.screen; })
      .filter(function (id) { return id !== 'capture' && id !== 'processing'; });

    track('quiz_started', { entry_step_id: firstStepId });
    if (window.etus && window.etus.setQuizLifecycle) {
      window.etus.setQuizLifecycle('in_progress', Object.assign({}, quizBase, {
        started_at: quizStartedAt,
        last_step_id: firstStepId,
        last_step_index: 0,
      }));
    }
    if (firstStepId) {
      track('quiz_step_viewed', {
        step_id: firstStepId,
        step_index: 0,
        step_kind: 'question',
      });
    }

    function indexOfScreen(id) {
      for (var i = 0; i < screens.length; i++) {
        if (screens[i].dataset.screen === id) return i;
      }
      return -1;
    }

    function setProgress(idx) {
      var ratio = Math.min(1, (idx + 1) / totalScreens);
      if (progressBar) progressBar.style.transform = 'scaleX(' + ratio + ')';
      if (progressLabel) progressLabel.textContent = (idx + 1) + ' / ' + totalScreens;
    }

    function showScreen(targetId, opts) {
      var pushHistory = !(opts && opts.skipHistory);
      var targetIdx = indexOfScreen(targetId);
      if (targetIdx < 0) return;
      var next = screens[targetIdx];
      if (!next) return;
      var current = screens.find(function (el) { return el.classList.contains('active'); });
      if (pushHistory && current && current !== next) {
        historyStack.push(current.dataset.screen);
      }
      screens.forEach(function (el) { el.classList.toggle('active', el === next); });
      setProgress(targetIdx);
      updateBackBtn(targetId);
      window.requestAnimationFrame(function () {
        var focusable = next.querySelector('button, input, [tabindex]');
        if (focusable && focusable.focus) focusable.focus({ preventScroll: true });
      });
    }

    function updateBackBtn(currentId) {
      if (!backBtn) return;
      // Hide on the first step and on the terminal processing screen.
      var canGoBack = historyStack.length > 0 && currentId !== 'processing';
      backBtn.hidden = !canGoBack;
    }

    if (backBtn) {
      backBtn.addEventListener('click', function () {
        var prev = historyStack.pop();
        if (!prev) return;
        showScreen(prev, { skipHistory: true });
      });
    }

    setProgress(0);
    updateBackBtn(screens[0] ? screens[0].dataset.screen : '');

    root.addEventListener('click', function (e) {
      var button = e.target && e.target.closest && e.target.closest('.options button[data-value]');
      if (!button) return;
      var list = button.closest('ul.options');
      if (!list) return;
      var stepId = list.dataset.stepId;
      var value = button.dataset.value;
      var label = (button.textContent || '').trim();
      var explicitNext = button.dataset.next || '';
      try {
        var raw = sessionStorage.getItem('quiz:answers') || '{}';
        var answers = JSON.parse(raw);
        answers[stepId] = value;
        sessionStorage.setItem('quiz:answers', JSON.stringify(answers));
      } catch (_) {}
      track('quiz_answer_selected', {
        step_id: stepId,
        step_index: indexOfStep(stepId),
        answer_value: value,
        answer_label: label,
        time_on_step_ms: Date.now() - stepEnteredAt,
      });
      var nextScreenId = explicitNext;
      if (!nextScreenId) {
        var currentIdx = indexOfScreen(stepId);
        var next = screens[currentIdx + 1];
        nextScreenId = next ? next.dataset.screen : '';
      }
      if (!nextScreenId) nextScreenId = hasCapture ? 'capture' : 'processing';
      showScreen(nextScreenId);
      stepEnteredAt = Date.now();
      if (nextScreenId === 'processing') {
        startRedirect();
      } else {
        var isCapture = nextScreenId === 'capture';
        track('quiz_step_viewed', {
          step_id: nextScreenId,
          step_index: isCapture ? stepIds.length : indexOfStep(nextScreenId),
          step_kind: isCapture ? 'capture' : 'question',
        });
        if (window.etus && window.etus.setQuizLifecycle) {
          var lc = window.etus.getQuizLifecycle() || {};
          window.etus.setQuizLifecycle('in_progress', Object.assign({}, lc, quizBase, {
            last_step_id: nextScreenId,
            last_step_index: isCapture ? stepIds.length : indexOfStep(nextScreenId),
            last_step_viewed_at: Date.now(),
          }));
        }
        if (isCapture) {
          formEnteredAt = Date.now();
          track('quiz_form_viewed', {
            step_id: 'capture',
            fields_shown: captureFields,
          });
        }
      }
    });

    function validityCode(v) {
      if (!v) return 'unknown';
      if (v.valueMissing) return 'value_missing';
      if (v.typeMismatch) return 'type_mismatch';
      if (v.patternMismatch) return 'pattern_mismatch';
      if (v.tooShort) return 'too_short';
      if (v.tooLong) return 'too_long';
      if (v.rangeUnderflow) return 'range_underflow';
      if (v.rangeOverflow) return 'range_overflow';
      if (v.stepMismatch) return 'step_mismatch';
      if (v.badInput) return 'bad_input';
      if (v.customError) return 'custom_error';
      return 'unknown';
    }

    var captureForm = document.querySelector('#capture-form');
    if (captureForm) {
      captureForm.addEventListener('submit', function (e) {
        e.preventDefault();
        var errors = [];
        for (var i = 0; i < captureForm.elements.length; i++) {
          var el = captureForm.elements[i];
          if (!el.willValidate || el.checkValidity()) continue;
          errors.push({
            field: el.name || el.id || '(unnamed-' + i + ')',
            type: el.type || null,
            error_code: validityCode(el.validity),
            error_message: el.validationMessage,
          });
        }
        if (errors.length) {
          for (var j = 0; j < errors.length; j++) track('quiz_form_error', errors[j]);
          captureForm.reportValidity();
          return;
        }
        // T2.13 — Manual reducer instead of Object.fromEntries(). The IIFE
        // runs on browsers that may lack Object.fromEntries (iOS Safari 11-,
        // older Android WebView). The loop has the same semantics with
        // wider compat.
        var formData = new FormData(captureForm);
        var lead = {};
        var formEntries = formData.entries();
        var entry = formEntries.next();
        while (!entry.done) {
          lead[entry.value[0]] = entry.value[1];
          entry = formEntries.next();
        }
        try { sessionStorage.setItem('quiz:lead', JSON.stringify(lead)); } catch (_) {}
        var formProperties = {
          time_on_form_ms: Date.now() - (formEnteredAt || Date.now()),
          has_name: 'name' in lead && !!lead.name,
          has_email: 'email' in lead && !!lead.email,
          has_phone: 'phone' in lead && !!lead.phone,
          consent_given: !!lead.consent,
        };
        // T1.2 — unified path: identify + track('quiz_form_submitted') w/ rich
        // properties (form, turnstile_token, answers, attribution) + flush().
        // Worker anti-fraud (T0.8/T0.10/T0.11/T1.17) reads from properties.
        if (window.etus && window.etus.identify && window.etus.track && window.etus.flush) {
          var traits = {};
          if (typeof lead.email === 'string' && lead.email) traits.email = lead.email;
          if (typeof lead.phone === 'string' && lead.phone) traits.phone = lead.phone;
          if (typeof lead.name === 'string' && lead.name) traits.name = lead.name;
          var answers = {};
          try { answers = JSON.parse(sessionStorage.getItem('quiz:answers') || '{}'); } catch (_) {}
          var formField = {
            email: typeof lead.email === 'string' ? lead.email : '',
            phone: typeof lead.phone === 'string' ? lead.phone : '',
            name: typeof lead.name === 'string' ? lead.name : '',
            website: typeof lead.website === 'string' ? lead.website : '',
          };
          var turnstileToken = typeof lead.turnstile_token === 'string' ? lead.turnstile_token : '';
          window.etus.identify(traits);
          window.etus.track('quiz_form_submitted', Object.assign({}, quizBase, formProperties, {
            answers: answers,
            form: formField,
            turnstile_token: turnstileToken,
            attribution: window.etus.attribution(),
          }));
          window.etus.flush();
        } else {
          // No worker target — at least update lifecycle for abandonment tracker
          track('quiz_form_submitted', formProperties);
        }
        showScreen('processing');
        startRedirect();
      });
    }

    function pickWeighted(urls) {
      var total = 0;
      for (var i = 0; i < urls.length; i++) total += urls[i].weight;
      var r = Math.random() * total;
      for (var j = 0; j < urls.length; j++) {
        r -= urls[j].weight;
        if (r <= 0) return urls[j].url;
      }
      return urls[urls.length - 1].url;
    }

    var redirectStarted = false;
    function resolveDest() {
      try {
        var cfg = JSON.parse(runtimeRaw);
        if (cfg.type === 'post') return cfg.href;
        if (cfg.type === 'weighted') return pickWeighted(cfg.urls);
        if (cfg.type === 'routed' || cfg.type === 'routed-external') {
          var answers = JSON.parse(sessionStorage.getItem('quiz:answers') || '{}');
          for (var i = 0; i < cfg.rules.length; i++) {
            var rule = cfg.rules[i];
            if (answers[rule.when.questionKey] === rule.when.answerKey) {
              return cfg.type === 'routed' ? rule.href : pickWeighted(rule.urls);
            }
          }
          return cfg.type === 'routed' ? cfg.default.href : pickWeighted(cfg.default);
        }
      } catch (_) {}
      return fallbackResult;
    }

    function startRedirect() {
      if (redirectStarted) return;
      redirectStarted = true;
      var dest = resolveDest();
      var destInternal = typeof dest === 'string' && dest.charAt(0) === '/';
      track('quiz_completed', {
        time_on_quiz_ms: Date.now() - quizStartedAt,
        destination_type: destInternal ? 'post' : 'external',
        destination_url: dest || null,
      });
      // T1.4 — flush before the redirect timer fires (location.replace after 2.5s)
      if (window.etus && window.etus.flush) window.etus.flush();
      if (window.etus && window.etus.setQuizLifecycle) {
        var lc = window.etus.getQuizLifecycle() || {};
        window.etus.setQuizLifecycle('completed', Object.assign({}, lc, {
          completed_at: Date.now(),
          destination_url: dest || null,
        }));
      }
      if (dest) window.setTimeout(function () { window.location.replace(dest); }, 2500);
    }
  })();
</script>

<style>
  .quiz-shell {
    max-width: 36rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  .quiz-topbar {
    display: grid;
    /* T2.25 — reserve a fixed 3rem slot for the back button. With auto sizing
       the progress bar jumped left/right whenever the back button mounted
       (first step doesn't render one), producing CLS. Pinning the column
       keeps the bar in place across navigation. */
    grid-template-columns: 3rem 1fr;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 2.5rem;
  }

  .quiz-topbar .progress {
    margin-bottom: 0;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    /* T1.16 — min 44pt tap target */
    min-height: 44px;
    padding: 0.625rem 0.875rem;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--color-fg) 12%, transparent);
    border-radius: 999px;
    color: var(--color-muted);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease,
      background-color 120ms ease;
  }

  .back-btn:hover,
  .back-btn:focus-visible {
    color: var(--color-fg);
    border-color: color-mix(in srgb, var(--color-fg) 24%, transparent);
    background: color-mix(in srgb, var(--color-fg) 4%, transparent);
    outline: none;
  }

  .back-btn[hidden] {
    display: none;
  }

  .progress {
    position: relative;
    height: 0.5rem;
    background: color-mix(in srgb, var(--color-fg) 8%, transparent);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-bar {
    /* Composited animation — transform: scaleX on GPU vs width forcing layout
       (Lighthouse "Avoid non-composited animations"). Initial scaleX(0) =
       empty bar; JS setProgress() animates to scaleX(idx/total). */
    position: absolute;
    inset: 0;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 320ms ease;
    will-change: transform;
  }

  .progress-label {
    /* T1.15 — moved above bar (was overlapping question H2 at 320px) */
    position: absolute;
    bottom: 100%;
    right: 0;
    margin-bottom: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .landing-intro {
    text-align: center;
    margin-bottom: 2rem;
  }

  .landing-intro h1 {
    font-size: clamp(1.75rem, 4.5vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    color: var(--color-primary);
  }

  /* CSS Grid stacking: all screens occupy the same cell, only `.active` is visible.
     Until JS marks the shell `.js-ready`, only the SSR-active screen is visible
     (others have `display:none` inline, no FOUC). */
  .screens {
    display: grid;
    grid-template-columns: 1fr;
  }

  .quiz-shell.js-ready .screen {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition:
      opacity 220ms ease,
      transform 220ms ease,
      visibility 220ms;
    pointer-events: none;
  }

  .quiz-shell.js-ready .screen.active {
    opacity: 1;
    visibility: visible;
    transform: none;
    pointer-events: auto;
    transition-delay: 60ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .screen {
      transition: none;
      transform: none;
    }
  }

  .step h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
  }

  .step h2 {
    font-size: clamp(1.25rem, 3vw, 1.625rem);
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }

  .lede {
    color: var(--color-muted);
    font-size: 1.0625rem;
    margin: 0 0 1.5rem;
  }

  .options {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .options button {
    width: 100%;
    text-align: left;
    padding: 1rem 1.25rem;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--color-fg) 12%, transparent);
    border-radius: 0.625rem;
    color: var(--color-fg);
    font-size: 1rem;
    transition:
      border-color 120ms ease,
      background-color 120ms ease;
  }

  .options button:hover,
  .options button:focus-visible {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 6%, transparent);
    outline: none;
  }

  .field {
    display: block;
    margin-bottom: 1rem;
  }

  .field span {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 0.375rem;
  }

  .field input {
    width: 100%;
    padding: 0.75rem 0.875rem;
    border: 1px solid color-mix(in srgb, var(--color-fg) 16%, transparent);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-fg);
  }

