---
// Classic theme — locale home page. EXTRACTED VERBATIM from the original
// [locale]/index.astro template+styles. Data + getStaticPaths stay in the route.
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { postMeta } from '../../lib/content';
import { quizPath, postPath, blogHubPath } from '../../lib/url';

export interface HomeViewProps {
  locale: string;
  display: ReturnType<typeof import('../../lib/tenant').localeDisplay>;
  featuredQuiz: CollectionEntry<'quiz'> | undefined;
  featuredQuizMeta: ReturnType<typeof postMeta> | null;
  posts: CollectionEntry<'post'>[];
  alternates: { hreflang: string; href: string }[];
}

const { locale, display, featuredQuiz, featuredQuizMeta, posts, alternates } =
  Astro.props as HomeViewProps;
---

<BaseLayout
  locale={locale}
  title={display.siteName}
  description={display.description}
  alternates={alternates}
>
  <Header locale={locale} />
  <main id="main">
    <section class="hero">
      <h1>{display.tagline}</h1>
      <p class="lede">{display.description}</p>
      {featuredQuiz && featuredQuizMeta && (
        <a
          class="cta"
          href={quizPath(locale, featuredQuizMeta.vertical, featuredQuizMeta.slug)}
        >
          {featuredQuiz.data.title} →
        </a>
      )}
    </section>

    {posts.length > 0 && (
      <section class="posts">
        <header class="posts-header">
          <h2>{display.nav.blog}</h2>
          <a class="see-all" href={blogHubPath(locale)}>{display.nav.blog} →</a>
        </header>
        <ul class="post-grid">
          {posts.map((post) => {
            const meta = postMeta(post);
            return (
              <li class="post-card">
                <a href={postPath(locale, meta.vertical, meta.slug)}>
                  <span class="post-vertical">{display.verticals[meta.vertical]}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  main {
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 0;
  }

  .hero {
    padding: 3rem 0 4rem;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 38rem;
    margin: 0 auto 2rem;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.5rem;
    background: var(--color-primary);
    color: #fff;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: transform 120ms ease;
  }

  .cta:hover {
    transform: translateY(-1px);
  }

  .posts {
    padding: 2rem 0;
  }

  .posts-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .posts-header h2 {
    margin: 0;
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }

  .see-all {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .post-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
  }

  .post-card a {
    display: block;
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-fg) 8%, transparent);
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease;
    height: 100%;
  }

  .post-card a:hover {
    border-color: var(--color-primary);
  }

  .post-vertical {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .post-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .post-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9375rem;
  }
</style>
