---
// Editorial theme — premium post card (shared by HubView + HomeView). Same props
// as the classic PostCard so it's a drop-in. Uses the shared --e-* tokens
// (themes/editorial/tokens.css, provided by the .ed wrapper). Thumbnail goes
// through pictureHtml (R2-ready, lazy, CLS-safe dims).
import type { CollectionEntry } from 'astro:content';
import { postMeta } from '../../lib/content';
import { postPath } from '../../lib/url';
import { pictureHtml } from '../../lib/images';

interface Props {
  post: CollectionEntry<'post'>;
  locale: string;
  verticalLabel: string;
  minReadLabel: string;
  /** Show the ogImage thumbnail. Default true. */
  image?: boolean;
}
const { post, locale, verticalLabel, minReadLabel, image = true } = Astro.props;
const meta = postMeta(post);
const href = postPath(locale, meta.vertical, meta.slug);
---

<li class="epc">
  <a href={href}>
    {image && post.data.ogImage && (
      <span class="epc-thumb" set:html={pictureHtml(post.data.ogImage, post.data.title)} />
    )}
    <span class="epc-body">
      <span class="epc-kicker">{verticalLabel}</span>
      <h3 class="epc-title">{post.data.title}</h3>
      <p class="epc-desc">{post.data.description}</p>
      <span class="epc-meta">
        {post.data.readingTimeMinutes} {minReadLabel} · {post.data.publishedAt.toLocaleDateString(locale)}
      </span>
    </span>
  </a>
</li>

<style>
  .epc {
    list-style: none;
  }

  .epc a {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 1rem;
    overflow: hidden;
    background: var(--e-surface-raised);
    border: 1px solid var(--e-line);
    text-decoration: none;
    color: inherit;
  }

  .epc-thumb {
    display: block;
  }

  .epc-thumb :global(img) {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .epc-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem;
  }

  .epc-kicker {
    font-family: var(--e-font-display);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--e-accent);
    margin-bottom: 0.55rem;
  }

  .epc-title {
    margin: 0 0 0.5rem;
    font-family: var(--e-font-display);
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--e-ink);
  }

  .epc-desc {
    margin: 0 0 1rem;
    font-family: var(--e-font-body);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--e-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .epc-meta {
    margin-top: auto;
    font-family: var(--e-font-display);
    font-size: 0.72rem;
    color: var(--e-muted);
  }

  @media (prefers-reduced-motion: no-preference) {
    .epc a {
      transition:
        border-color 140ms ease,
        transform 140ms ease,
        box-shadow 140ms ease;
    }
    .epc a:hover {
      border-color: var(--e-accent);
      transform: translateY(-2px);
      box-shadow: var(--e-shadow);
    }
  }
</style>
