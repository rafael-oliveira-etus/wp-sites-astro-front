---
// Editorial theme — FAQ accordion (native <details>: keyboard-accessible, no JS).
// The matching FAQPage JSON-LD is emitted by the route (buildFaqSchema) — this is
// the visible half. Renders nothing when there are no items.
interface Props {
  items: { q: string; a: string }[];
  heading: string;
}
const { items, heading } = Astro.props;
---

{items.length > 0 && (
  <section class="faq ed-reveal" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="faq-heading">{heading}</h2>
    <div class="faq-list">
      {items.map((item) => (
        <details class="faq-item">
          <summary>
            <span>{item.q}</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>
)}

<style>
  .faq {
    margin: 3rem 0;
  }

  .faq-heading {
    margin: 0 0 1.25rem;
    font-family: var(--e-font-display);
    font-size: var(--e-h2);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--e-ink);
  }

  .faq-list {
    display: grid;
    gap: 0.6rem;
  }

  .faq-item {
    border: 1px solid var(--e-line);
    border-radius: 0.85rem;
    background: var(--e-surface-raised);
    overflow: hidden;
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.3rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--e-font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--e-ink);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    flex: none;
    color: var(--e-muted);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-item p {
    margin: 0;
    padding: 0 1.3rem 1.3rem;
    font-family: var(--e-font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--e-ink);
  }

  .faq-item summary:focus-visible {
    outline: 2px solid var(--e-accent);
    outline-offset: -2px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .faq-chevron {
      transition: transform 160ms ease;
    }
  }
</style>
