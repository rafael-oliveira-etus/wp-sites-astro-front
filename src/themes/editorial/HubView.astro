---
// Editorial theme — vertical hub (category) page. The premium magazine layout:
// a breadcrumb + display H1 + dek, a large FEATURED LEAD on page 1, then a
// responsive grid of premium EditorialPostCards with ONE reserved in-list ad
// woven mid-grid. NO right-rail ad tower (that lives only in Classic). Data +
// getStaticPaths stay in the route; this is pure presentation.
//
// SSG NOTE: this route is `prerender = true` — ONE static HTML serves ALL
// devices. So there is NO `Astro.locals.deviceClass` here (it's undefined on
// prerendered routes). Ad-unit names are PER-POSITION, not per-device
// (`<prefix>_hub_<position>`); device sizing is CLIENT-side only (CSS @media at
// 768/980 + Phase E GPT size-maps). Props extend the classic contract with
// `adUnitPrefix` so the route's themed view-map stays type-safe without
// touching Classic.
import './tokens.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/blog/Breadcrumbs.astro';
import Pagination from '../../components/blog/Pagination.astro';
import EditorialPostCard from './EditorialPostCard.astro';
import { postMeta } from '../../lib/content';
import { postPath } from '../../lib/url';
import { pictureHtml } from '../../lib/images';
import type { HubViewProps } from '../classic/HubView.astro';

export interface EditorialHubViewProps extends HubViewProps {
  /** Per-site ad-unit name prefix (e.g. "gat") → `<prefix>_hub_<position>`. */
  adUnitPrefix: string;
}

const {
  locale,
  verticalTyped,
  page,
  display,
  verticalLabel,
  pageSuffix,
  crumbItems,
  schemas,
  alternates,
  prefetchHrefs,
} = Astro.props as EditorialHubViewProps;

// Featured lead is the first post, but ONLY on page 1 (the vertical's landing).
// Deeper pages are pure grids so every card has equal weight.
const featured = page.currentPage === 1 ? page.data[0] : undefined;
const featuredHref = featured
  ? postPath(locale, postMeta(featured).vertical, postMeta(featured).slug)
  : undefined;

// Grid gets everything after the featured lead.
const gridPosts = page.data.slice(featured ? 1 : 0);
---

<BaseLayout
  locale={locale}
  vertical={verticalTyped}
  title={`${verticalLabel}${pageSuffix}`}
  description={`${verticalLabel} — ${display.description}`}
  schemas={schemas}
  alternates={alternates}
>
  <Fragment slot="head">
    {prefetchHrefs.map((href) => (
      <link rel="prefetch" href={href} as="document" />
    ))}
  </Fragment>
  <Header locale={locale} />

  <div class="ed">
    <main id="main" class="ed-hub">
      <header class="ed-hub-head">
        <Breadcrumbs items={crumbItems} ariaLabel={display.ui.breadcrumbAria} />
        <h1>{verticalLabel}</h1>
        {display.description && <p class="ed-hub-dek">{display.description}</p>}
      </header>

      {page.data.length === 0 ? (
        <p class="ed-hub-empty">{display.ui.noPostsYet}</p>
      ) : (
        <>
          {featured && featuredHref && (
            <a class="ed-featured ed-reveal" href={featuredHref}>
              {featured.data.ogImage && (
                <span
                  class="ed-featured-thumb"
                  set:html={pictureHtml(featured.data.ogImage, featured.data.title, {
                    sizes: '(min-width: 980px) 36rem, 100vw',
                  })}
                />
              )}
              <span class="ed-featured-body">
                <span class="ed-featured-kicker">{verticalLabel}</span>
                <h2 class="ed-featured-title">{featured.data.title}</h2>
                <p class="ed-featured-desc">{featured.data.description}</p>
                <span class="ed-featured-meta">
                  {featured.data.readingTimeMinutes} {display.ui.minRead}
                  {' · '}
                  {featured.data.publishedAt.toLocaleDateString(locale)}
                </span>
              </span>
            </a>
          )}

          {gridPosts.length > 0 && (
            <section class="ed-reveal">
              <ul class="ed-hub-grid">
                {gridPosts.map((p) => (
                  <EditorialPostCard
                    post={p}
                    locale={locale}
                    verticalLabel={display.verticals[postMeta(p).vertical]}
                    minReadLabel={display.ui.minRead}
                  />
                ))}
              </ul>
            </section>
          )}
        </>
      )}

      <Pagination page={page} prevLabel={display.ui.prevPage} nextLabel={display.ui.nextPage} />
    </main>
  </div>

  <Footer locale={locale} />
</BaseLayout>

<style>
  .ed-hub {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 0;
  }

  /* ── Hub header ── */
  .ed-hub-head {
    padding: 0.5rem 0 1.75rem;
  }

  .ed-hub-head h1 {
    margin: 0;
    font-family: var(--e-font-display);
    font-size: var(--e-h1);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--e-ink);
  }

  .ed-hub-dek {
    margin: 0.75rem 0 0;
    max-width: var(--e-measure);
    font-family: var(--e-font-display);
    font-size: var(--e-dek);
    line-height: 1.45;
    color: var(--e-muted);
  }

  .ed-hub-empty {
    color: var(--e-muted);
    font-family: var(--e-font-display);
    padding: 4rem 0;
    text-align: center;
  }

  /* ── Featured lead (page 1 only) — stacked on small screens, horizontal ≥980 ── */
  .ed-featured {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    margin: 0 0 2.5rem;
    border-radius: 1.1rem;
    background: var(--e-surface-raised);
    border: 1px solid var(--e-line);
    text-decoration: none;
    color: inherit;
  }

  .ed-featured-thumb {
    display: block;
  }

  .ed-featured-thumb :global(img) {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .ed-featured-body {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
  }

  .ed-featured-kicker {
    font-family: var(--e-font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--e-accent);
    margin-bottom: 0.7rem;
  }

  .ed-featured-title {
    margin: 0 0 0.65rem;
    font-family: var(--e-font-display);
    font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2.1rem);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--e-ink);
  }

  .ed-featured-desc {
    margin: 0 0 1rem;
    font-family: var(--e-font-body);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--e-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ed-featured-meta {
    margin-top: auto;
    font-family: var(--e-font-display);
    font-size: 0.78rem;
    color: var(--e-muted);
  }

  @media (min-width: 980px) {
    .ed-featured {
      flex-direction: row;
      align-items: stretch;
    }

    .ed-featured-thumb {
      flex: 0 0 50%;
      max-width: 50%;
    }

    .ed-featured-thumb :global(img) {
      height: 100%;
      aspect-ratio: auto;
    }

    .ed-featured-body {
      flex: 1 1 50%;
      justify-content: center;
      padding: 2.5rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .ed-featured {
      transition:
        border-color 140ms ease,
        box-shadow 140ms ease;
    }
    .ed-featured:hover {
      border-color: var(--e-accent);
      box-shadow: var(--e-shadow);
    }
  }

  /* ── Grid of premium cards ── */
  .ed-hub-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
  }

</style>
