---
// Editorial theme — the post's affiliate exit as a DESIGNED recommendation card
// (not a bare button), with an adjacent advertiser disclosure for compliance.
// The CTA keeps class `exit-link` so the post's analytics script binds to it
// exactly as on the classic theme (exit_link_clicked + time-on-post).
interface Props {
  url: string;
  label: string;
  pickLabel: string;
  verticalLabel: string;
  disclosure: string;
}
const { url, label, pickLabel, verticalLabel, disclosure } = Astro.props;
---

<aside class="pick ed-reveal">
  <div class="pick-head">
    <span class="pick-kicker">{pickLabel}</span>
    <span class="pick-vertical">{verticalLabel}</span>
  </div>
  <a class="exit-link pick-cta" href={url} rel="sponsored noopener" target="_blank">
    <span>{label}</span>
    <svg class="pick-arrow" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </a>
  <p class="pick-disclosure">{disclosure}</p>
</aside>

<style>
  .pick {
    margin: 2.5rem 0;
    padding: 1.75rem;
    border-radius: 1.1rem;
    background: var(--e-surface-raised);
    border: 1px solid var(--e-line);
    box-shadow: var(--e-shadow);
  }

  .pick-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .pick-kicker {
    font-family: var(--e-font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--e-accent);
  }

  .pick-vertical {
    font-family: var(--e-font-display);
    font-size: 0.75rem;
    color: var(--e-muted);
    padding-left: 0.75rem;
    border-left: 1px solid var(--e-line);
  }

  .pick-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: 1rem 1.4rem;
    background: var(--e-accent);
    color: #fff;
    font-family: var(--e-font-display);
    font-size: 1.0625rem;
    font-weight: 650;
    line-height: 1.25;
    border-radius: 0.7rem;
    text-decoration: none;
  }

  .pick-arrow {
    flex: none;
    transform: translateX(0);
  }

  .pick-disclosure {
    margin: 0.85rem 0 0;
    font-family: var(--e-font-display);
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--e-muted);
  }

  @media (prefers-reduced-motion: no-preference) {
    .pick-cta {
      transition:
        transform 140ms ease,
        box-shadow 140ms ease;
    }
    .pick-cta:hover {
      transform: translateY(-1px);
    }
    .pick-arrow {
      transition: transform 140ms ease;
    }
    .pick-cta:hover .pick-arrow {
      transform: translateX(3px);
    }
  }
</style>
