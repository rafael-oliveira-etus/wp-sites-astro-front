---
// Editorial theme — post page. The premium reading-lane redesign: ONE centered
// 66ch column, NO right rail, left-margin sticky TOC, answer-first Key Takeaways,
// one top AdSlot marker, Editor's-pick card, FAQ (+FAQPage JSON-LD),
// dismissible sticky bottom anchor. Data is fetched in the route; this is pure
// presentation. Uses the shared PostViewProps contract (bodyHtml string).
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WebpushPrompt from '../../components/WebpushPrompt.astro';
import AdSlot from '../../components/blog/AdSlot.astro';
import ShareBar from '../../components/blog/ShareBar.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import Toc from '../../components/blog/Toc.astro';
import ReadingProgress from '../../components/blog/ReadingProgress.astro';
import AuthorBio from '../../components/blog/AuthorBio.astro';
import KeyTakeaways from './KeyTakeaways.astro';
import EditorPickCard from './EditorPickCard.astro';
import Faq from './Faq.astro';
import type { PostViewProps } from '../classic/PostView.astro';
import { pictureHtml } from '../../lib/images';
import './tokens.css';

const {
  locale,
  verticalTyped,
  post,
  display,
  canonicalUrl,
  bodyHtml,
  headings,
  showToc,
  author,
  authorUrl,
  alternates,
  schemas,
  related,
  prefetchHrefs,
} = Astro.props as PostViewProps;

const verticalLabel = display.verticals[verticalTyped];
---

<BaseLayout
  locale={locale}
  vertical={verticalTyped}
  title={post.seoTitle ?? post.title}
  description={post.description}
  type="article"
  image={post.ogImage}
  publishedTime={post.publishedAt.toISOString()}
  modifiedTime={post.updatedAt.toISOString()}
  author={author.name}
  schemas={schemas}
  alternates={alternates}
>
  <Fragment slot="head">
    {prefetchHrefs.map((href) => (
      <link rel="prefetch" href={href} as="document" />
    ))}
  </Fragment>
  <ReadingProgress />
  <Header locale={locale} />

  <div class="ed">
    {/* Top ad marker — the external ad worker fills/sizes it (see AdSlot). */}
    <div class="ed-topad"><AdSlot position="top" /></div>

    <div class="ed-grid">
      <aside class="ed-rail-left">
        {showToc && <Toc headings={headings} title={display.ui.onThisPage} />}
      </aside>

      <article id="main" class="ed-col">
        <header class="ed-hero">
          <span class="ed-kicker">{verticalLabel}</span>
          <h1>{post.title}</h1>
          <p class="ed-dek">{post.description}</p>
          <div class="ed-byline">
            {author.avatar ? (
              <img class="ed-avatar" src={author.avatar} alt={author.name} width="44" height="44" loading="lazy" decoding="async" />
            ) : (
              <span class="ed-avatar ed-avatar-fallback" aria-hidden="true">{author.name.charAt(0)}</span>
            )}
            <div class="ed-byline-text">
              <span class="ed-byline-name">
                {display.ui.by} <a href={authorUrl}>{author.name}</a>
              </span>
              <span class="ed-byline-meta">
                <time datetime={post.publishedAt.toISOString()}>
                  {post.publishedAt.toLocaleDateString(locale)}
                </time>
                <span aria-hidden="true">·</span>
                <span>{post.readingTimeMinutes} {display.ui.minRead}</span>
              </span>
            </div>
          </div>
        </header>


        {post.ogImage && (
          <figure
            class="ed-lead ed-reveal"
            set:html={pictureHtml(post.ogImage, post.title, {
              eager: true,
              sizes: '(min-width: 980px) 52rem, 100vw',
            })}
          />
        )}

        <div class="ed-lane">
          <KeyTakeaways items={post.keyTakeaways} title={display.ui.keyTakeaways} />

          <div class="ed-prose ed-prose-lead" set:html={bodyHtml} />

          <EditorPickCard
            url={post.exitLink.url}
            label={post.exitLink.label}
            pickLabel={display.ui.editorsPick}
            verticalLabel={verticalLabel}
            disclosure={display.ui.affiliateDisclosure}
          />

          <Faq items={post.faq} heading={display.ui.faqHeading} />

          <ShareBar
            url={canonicalUrl}
            title={post.title}
            shareLabel={display.ui.share}
            copyLabel={display.ui.copyLink}
            copiedLabel={display.ui.linkCopied}
          />

          <AuthorBio author={author} locale={locale} reviewedByLabel={display.ui.reviewedBy} />

          <div class="ed-tail">
            <RelatedPosts posts={related} locale={locale} heading={display.ui.relatedPosts} />
          </div>
        </div>
      </article>
    </div>

    {/* Bottom anchor is GPT-NATIVE (OutOfPageFormat.BOTTOM_ANCHOR): Google
       renders, pins and dismisses it as an out-of-page slot. Booted in Phase E
       via the `anchor` placement + @etus/ads bootAnchorScript — NOT a hand-rolled
       fixed div (anchor has no in-page box to reserve, unlike top/in-content/end). */}
  </div>

  <Footer locale={locale} />
  <WebpushPrompt locale={locale} surface="post" />
  <script
    is:inline
    nonce={Astro.locals.nonce}
    data-astro-rerun
    define:vars={{
      postProps: {
        post_slug: post.slug,
        vertical: verticalTyped,
        reading_time_min: post.readingTimeMinutes,
        related_count: related.length,
        author_name: author.name,
        published_at: post.publishedAt.toISOString(),
        updated_at: post.updatedAt.toISOString(),
      },
    }}
  >
    if (window.etus && window.etus.track) {
      var loadedAt = Date.now();
      window.etus.track('post_viewed', postProps);
      var link = document.querySelector('a.exit-link');
      if (link) {
        link.addEventListener('click', function () {
          window.etus.track('exit_link_clicked', Object.assign({}, postProps, {
            exit_url: link.href,
            exit_label: (link.textContent || '').trim(),
            time_on_post_ms: Date.now() - loadedAt,
          }));
          if (window.etus.flushBeacon) window.etus.flushBeacon();
        });
      }
    }
  </script>
</BaseLayout>

<style>
  /* Editorial tokens (--e-*), the .ed base and the ed-reveal animation now live in
     the shared ./tokens.css (imported above) — single-sourced across
     PostView/HubView/HomeView. This file keeps only POST-specific layout. */

  /* ── Layout: left-margin TOC + centered reading lane ── */
  .ed-grid {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 78rem;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  @media (min-width: 980px) {
    .ed-grid {
      grid-template-columns: 15rem minmax(0, var(--e-measure));
      justify-content: center;
      column-gap: 4rem;
      align-items: start;
    }
  }

  .ed-rail-left {
    display: none;
  }

  @media (min-width: 980px) {
    .ed-rail-left {
      display: block;
      position: sticky;
      top: 5rem;
      padding-top: 3.5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }
  }

  .ed-col {
    min-width: 0;
    max-width: var(--e-measure);
    width: 100%;
    margin: 0 auto;
  }

  /* ── Hero ── */
  .ed-hero {
    padding: 1.5rem 0 1.25rem;
  }

  .ed-kicker {
    display: inline-block;
    margin: 0 0 0.7rem;
    font-family: var(--e-font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--e-accent);
  }

  .ed-hero h1 {
    margin: 0 0 1rem;
    font-family: var(--e-font-display);
    font-size: var(--e-h1);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--e-ink);
  }

  .ed-dek {
    margin: 0 0 1.25rem;
    font-family: var(--e-font-display);
    font-size: var(--e-dek);
    font-weight: 400;
    line-height: 1.45;
    color: var(--e-muted);
  }

  .ed-byline {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .ed-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex: none;
  }

  .ed-avatar-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--e-accent-soft);
    color: var(--e-accent);
    font-family: var(--e-font-display);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .ed-byline-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-family: var(--e-font-display);
  }

  .ed-byline-name {
    font-size: 0.95rem;
    color: var(--e-ink);
  }

  .ed-byline-name a {
    color: var(--e-ink);
    font-weight: 650;
    text-decoration: none;
  }

  .ed-byline-name a:hover {
    color: var(--e-accent);
  }

  .ed-byline-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--e-muted);
  }

  /* ── Lead image ── */
  .ed-lead {
    margin: 0.5rem 0 0;
  }

  .ed-lead :global(img) {
    width: 100%;
    border-radius: 1rem;
  }

  .ed-lane {
    padding-top: 2rem;
  }

  /* ── Prose (set:html — needs :global) ── */
  .ed-prose {
    font-family: var(--e-font-body);
    font-size: var(--e-body);
    line-height: 1.75;
    color: var(--e-ink);
  }

  .ed-prose :global(p) {
    margin: 0 0 1.4rem;
  }

  .ed-prose :global(h2) {
    margin: 2.75rem 0 1rem;
    font-family: var(--e-font-display);
    font-size: var(--e-h2);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--e-ink);
    scroll-margin-top: 5rem;
  }

  .ed-prose :global(h3) {
    margin: 2rem 0 0.75rem;
    font-family: var(--e-font-display);
    font-size: var(--e-h3);
    font-weight: 650;
    letter-spacing: -0.01em;
    color: var(--e-ink);
    scroll-margin-top: 5rem;
  }

  .ed-prose :global(a) {
    color: var(--e-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .ed-prose :global(strong) {
    font-weight: 700;
  }

  .ed-prose :global(ul),
  .ed-prose :global(ol) {
    margin: 0 0 1.4rem;
    padding-left: 1.4rem;
  }

  .ed-prose :global(li) {
    margin: 0 0 0.35rem;
  }

  /* Loose lists (blank-line-separated bullets from imported content) render as
     <li><p>…</p></li>; drop the inner paragraph margin so bullets aren't double-
     spaced by the body paragraph rule. */
  .ed-prose :global(li p) {
    margin: 0;
  }

  .ed-prose :global(blockquote) {
    margin: 2rem 0;
    padding: 0.25rem 0 0.25rem 1.5rem;
    border-left: 3px solid var(--e-accent);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--e-muted);
  }

  .ed-prose :global(img),
  .ed-prose :global(picture) {
    border-radius: 0.85rem;
    margin: 1.75rem 0;
  }

  .ed-prose :global(figure) {
    margin: 1.75rem 0;
  }

  .ed-prose :global(figcaption) {
    margin-top: 0.6rem;
    font-family: var(--e-font-display);
    font-size: 0.8125rem;
    color: var(--e-muted);
    text-align: center;
  }

  .ed-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-family: var(--e-font-display);
    font-size: 0.9375rem;
  }

  .ed-prose :global(th),
  .ed-prose :global(td) {
    text-align: left;
    padding: 0.65rem 0.8rem;
    border-bottom: 1px solid var(--e-line);
  }

  .ed-prose :global(th) {
    font-weight: 650;
  }

  .ed-prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: var(--e-accent-tint);
    padding: 0.1em 0.35em;
    border-radius: 0.3rem;
  }

  .ed-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--e-line);
    margin: 2.5rem 0;
  }

  /* Top billboard — FULL-BLEED: 100% width, no margin/padding/border (edge-to-
     edge), first element after the header. Desktop + tablet only. */
  .ed-topad {
    width: 100%;
  }

  /* Below-fold tail (related posts) — skip offscreen layout/paint until near the
     viewport for faster render (CWV). Reserve an estimated height so there's no
     scroll-jump. ed-reveal lives in tokens.css. */
  .ed-tail {
    content-visibility: auto;
    contain-intrinsic-size: 0 600px;
  }
</style>
