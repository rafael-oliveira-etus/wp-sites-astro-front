---
// Locale home — prerendered. THIN RESOLVER: data + getStaticPaths here; presentation
// handed to the active theme's HomeView.
export const prerender = true;
import { TENANT, localeDisplay } from '../../lib/tenant';
import {
  quizzesByLocale,
  postsByLocale,
  postsByLocaleAndVertical,
  quizMeta,
  postMeta,
} from '../../lib/content';
import { localePath, absoluteUrl } from '../../lib/url';
import { VERTICALS } from '../../lib/schemas';
import ClassicHomeView from '../../themes/classic/HomeView.astro';
import EditorialHomeView from '../../themes/editorial/HomeView.astro';

const HOME_VIEWS = { classic: ClassicHomeView, editorial: EditorialHomeView } as const;

export async function getStaticPaths() {
  return TENANT.locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const display = localeDisplay(TENANT, locale);

const quizzes = await quizzesByLocale(locale);
const featuredQuiz = quizzes[0];
const featuredQuizMeta = featuredQuiz ? quizMeta(featuredQuiz) : null;

const posts = (await postsByLocale(locale))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 6);

// Editorial home renders CURATED per-vertical rows instead of one flat grid.
// Build one section per vertical that has posts (newest 4), excluding the
// featured post (posts[0]) so it isn't duplicated in its own vertical row.
const featuredSlug = posts[0] ? postMeta(posts[0]).slug : null;
const sections = (
  await Promise.all(
    VERTICALS.map(async (vertical) => {
      const vPosts = (await postsByLocaleAndVertical(locale, vertical))
        .filter((p) => postMeta(p).slug !== featuredSlug)
        .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
        .slice(0, 4);
      return { vertical, label: display.verticals[vertical] ?? vertical, posts: vPosts };
    }),
  )
).filter((s) => s.posts.length > 0);

// T1.5.B15 — locale homepage hreflang map (multi-locale tenants).
const alternates = TENANT.locales.map((altLocale) => ({
  hreflang: altLocale,
  href: absoluteUrl(TENANT, localePath(altLocale)),
}));

const HomeView = HOME_VIEWS[TENANT.theme] ?? ClassicHomeView;
---

<HomeView
  locale={locale}
  display={display}
  featuredQuiz={featuredQuiz}
  featuredQuizMeta={featuredQuizMeta}
  posts={posts}
  sections={sections}
  adUnitPrefix={TENANT.adUnitPrefix ?? TENANT.id}
  alternates={alternates}
/>
