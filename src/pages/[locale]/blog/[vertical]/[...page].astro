---
// SSR-spike: vertical hub + pagination kept prerendered (uses getStaticPaths).
// THIN RESOLVER: data + getStaticPaths here; presentation handed to the active theme's HubView.
export const prerender = true;
import { TENANT, localeDisplay } from '../../../../lib/tenant';
import { postsByLocaleAndVertical, postMeta } from '../../../../lib/content';
import { postPath, blogHubPath, verticalHubPath, absoluteUrl } from '../../../../lib/url';
import { VERTICALS, type Vertical } from '../../../../lib/schemas';
import { buildBreadcrumbSchema } from '../../../../lib/seo';
import ClassicHubView from '../../../../themes/classic/HubView.astro';
import EditorialHubView from '../../../../themes/editorial/HubView.astro';

const HUB_VIEWS = { classic: ClassicHubView, editorial: EditorialHubView } as const;

// getStaticPaths runs in an isolated scope — keep constants it uses local.
// Pagination is hand-built so deeper pages live under `/blog/<vertical>/page/<n>`
// (page 1 = the bare `/blog/<vertical>`). The default Astro `paginate()` puts page
// 2 at `/blog/<vertical>/2`, which COLLIDES with the post route
// `/blog/<vertical>/[slug]` — the SSR post route wins in dev and 404s ("Post not
// found"). The `/page/<n>` namespace can never match the single-segment [slug].
export async function getStaticPaths() {
  const PAGE_SIZE = 24;
  const routes = [];
  for (const locale of TENANT.locales) {
    for (const v of VERTICALS) {
      const posts = (await postsByLocaleAndVertical(locale, v)).sort(
        (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
      );
      const lastPage = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
      const base = `/${locale}/blog/${v}`;
      const pageUrl = (n: number) => (n <= 1 ? base : `${base}/page/${n}`);
      for (let cp = 1; cp <= lastPage; cp++) {
        const start = (cp - 1) * PAGE_SIZE;
        const data = posts.slice(start, start + PAGE_SIZE);
        const page = {
          data,
          start,
          end: start + data.length - 1,
          size: PAGE_SIZE,
          total: posts.length,
          currentPage: cp,
          lastPage,
          url: {
            current: pageUrl(cp),
            prev: cp > 1 ? pageUrl(cp - 1) : undefined,
            next: cp < lastPage ? pageUrl(cp + 1) : undefined,
            first: pageUrl(1),
            last: pageUrl(lastPage),
          },
        };
        routes.push({
          // page 1 → bare hub (rest param undefined); page n≥2 → `page/<n>`.
          params: { locale, vertical: v, page: cp === 1 ? undefined : `page/${cp}` },
          props: { page },
        });
      }
    }
  }
  return routes;
}

const { locale, vertical } = Astro.params;
const { page } = Astro.props;
const verticalTyped = vertical as Vertical;
const display = localeDisplay(TENANT, locale);
const verticalLabel = display.verticals[verticalTyped];

// Only prefetch on page 1 (above-the-fold landing for the vertical).
const prefetchHrefs =
  page.currentPage === 1
    ? page.data.slice(0, 4).map((p) => {
        const m = postMeta(p);
        return postPath(locale, m.vertical, m.slug);
      })
    : [];

const crumbItems = [
  { label: display.nav.home, href: `/${locale}` },
  { label: display.nav.blog, href: blogHubPath(locale) },
  { label: verticalLabel },
];
const breadcrumb = buildBreadcrumbSchema(
  crumbItems.map((c) => ({
    name: c.label,
    url: absoluteUrl(TENANT, c.href ?? verticalHubPath(locale, verticalTyped)),
  })),
);

// Page 1 is the canonical vertical hub across locales; deeper pages self-canonical.
const alternates =
  page.currentPage === 1
    ? TENANT.locales.map((altLocale) => ({
        hreflang: altLocale,
        href: absoluteUrl(TENANT, verticalHubPath(altLocale, verticalTyped)),
      }))
    : [];

const pageSuffix = page.lastPage > 1 ? ` — ${page.currentPage}/${page.lastPage}` : '';

const HubView = HUB_VIEWS[TENANT.theme] ?? ClassicHubView;
---

<HubView
  locale={locale}
  verticalTyped={verticalTyped}
  page={page}
  display={display}
  verticalLabel={verticalLabel}
  pageSuffix={pageSuffix}
  crumbItems={crumbItems}
  schemas={[breadcrumb]}
  alternates={alternates}
  prefetchHrefs={prefetchHrefs}
  adUnitPrefix={TENANT.adUnitPrefix ?? TENANT.id}
/>
