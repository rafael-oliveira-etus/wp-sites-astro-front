---
// SSR-spike: blog hub kept prerendered (uses getStaticPaths). Only the per-post
// reader ([slug].astro) is flipped to SSR for this spike.
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/blog/PostCard.astro';
import { TENANT, localeDisplay } from '../../../lib/tenant';
import { postsByLocale, postMeta } from '../../../lib/content';
import { postPath, verticalHubPath, absoluteUrl, blogHubPath } from '../../../lib/url';
import { VERTICALS } from '../../../lib/schemas';
import { buildBreadcrumbSchema } from '../../../lib/seo';

const RECENT_COUNT = 12;

export async function getStaticPaths() {
  return TENANT.locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const display = localeDisplay(TENANT, locale);

// Landing surface: most-recent across verticals, capped. Full per-vertical
// lists live on the paginated vertical hubs (linked via the tabs).
const recent = (await postsByLocale(locale))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, RECENT_COUNT);

const breadcrumb = buildBreadcrumbSchema([
  { name: display.nav.home, url: absoluteUrl(TENANT, `/${locale}`) },
  { name: display.nav.blog, url: absoluteUrl(TENANT, blogHubPath(locale)) },
]);

const prefetchHrefs = recent.slice(0, 4).map((p) => {
  const m = postMeta(p);
  return postPath(locale, m.vertical, m.slug);
});

const alternates = TENANT.locales.map((altLocale) => ({
  hreflang: altLocale,
  href: absoluteUrl(TENANT, blogHubPath(altLocale)),
}));
---

<BaseLayout
  locale={locale}
  title={display.nav.blog}
  description={display.description}
  schemas={[breadcrumb]}
  alternates={alternates}
>
  <Fragment slot="head">
    {prefetchHrefs.map((href) => (
      <link rel="prefetch" href={href} as="document" />
    ))}
  </Fragment>
  <Header locale={locale} />
  <main id="main">
    <header class="hub-header">
      <h1>{display.nav.blog}</h1>
      <ul class="vertical-tabs">
        {VERTICALS.map((v) => (
          <li>
            <a href={verticalHubPath(locale, v)}>{display.verticals[v]}</a>
          </li>
        ))}
      </ul>
    </header>

    {recent.length === 0 ? (
      <p class="empty">{display.ui.noPostsYet}</p>
    ) : (
      <ul class="post-grid">
        {recent.map((post) => (
          <PostCard
            post={post}
            locale={locale}
            verticalLabel={display.verticals[postMeta(post).vertical]}
            minReadLabel={display.ui.minRead}
          />
        ))}
      </ul>
    )}
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  main {
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 0;
  }

  .hub-header {
    padding: 2rem 0;
  }

  .hub-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .vertical-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .vertical-tabs a {
    display: inline-block;
    padding: 0.5rem 0.875rem;
    background: color-mix(in srgb, var(--color-fg) 6%, transparent);
    border-radius: 999px;
    color: var(--color-fg);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .vertical-tabs a:hover {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
  }

  .empty {
    color: var(--color-muted);
    padding: 4rem 0;
    text-align: center;
  }

  .post-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
  }
</style>
