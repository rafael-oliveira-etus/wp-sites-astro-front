---
export const prerender = true;
import QuizStepView from '../../../../../components/QuizStepView.astro';
import { allQuizzes, quizMeta } from '../../../../../lib/content';
import type { Vertical } from '../../../../../lib/schemas';

export async function getStaticPaths() {
  const quizzes = await allQuizzes();
  const paths: Array<{
    params: { locale: string; vertical: string; slug: string; step: string };
    props: { entryId: string };
  }> = [];

  for (const entry of quizzes) {
    // SPA quizzes only have a single bare URL.
    if (entry.data.mode === 'spa') continue;
    const meta = quizMeta(entry);
    // Skip first step — it lives at the bare URL (`/[slug]`).
    for (const s of entry.data.steps.slice(1)) {
      paths.push({
        params: { locale: meta.locale, vertical: meta.vertical, slug: meta.slug, step: s.id },
        props: { entryId: entry.id },
      });
    }
    if (entry.data.capture) {
      paths.push({
        params: { locale: meta.locale, vertical: meta.vertical, slug: meta.slug, step: 'capture' },
        props: { entryId: entry.id },
      });
    }
    paths.push({
      params: { locale: meta.locale, vertical: meta.vertical, slug: meta.slug, step: 'processing' },
      props: { entryId: entry.id },
    });
  }
  return paths;
}

const { locale, vertical, slug, step } = Astro.params;
const { entryId } = Astro.props;

const allEntries = await allQuizzes();
const entry = allEntries.find((e) => e.id === entryId);
if (!entry) throw new Error(`Quiz not found: ${entryId}`);
const quiz = entry.data;
---

<QuizStepView
  locale={locale}
  vertical={vertical as Vertical}
  slug={slug}
  step={step}
  quiz={quiz}
/>
