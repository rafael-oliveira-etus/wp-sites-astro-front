---
// SSR (not prerendered): a prerendered 404 can't be the target of Astro.rewrite()
// from an on-demand route (the SSR post route renders this for a missing post via
// `Astro.rewrite('/404')`). As a Worker, SSR-rendering the 404 is fine.
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogLayout from '../layouts/BlogLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localeDisplay } from '../lib/tenant';
const TENANT = Astro.locals.tenant;
import { localePath } from '../lib/url';

Astro.response.status = 404;
// Single 404 component for all locales — use the tenant's default locale copy.
const locale = TENANT.defaultLocale;
const display = localeDisplay(TENANT, locale);
const Layout = TENANT.blog?.wpBaseUrl ? BlogLayout : BaseLayout;
// Headless WP-REST tenants serve flat permalinks at `/` (there is no `/<locale>`
// route); the quiz model lived under `/<locale>`. Match the Header's home link
// so the 404 CTA never points at a non-existent localized path.
const homeHref = TENANT.blog?.wpBaseUrl ? '/' : localePath(locale);
---

<Layout
  locale={locale}
  title={display.notFound.heading}
  description={display.notFound.subheading}
  noindex={true}
>
  <Header locale={locale} />
  <main id="main" class="not-found">
    <p class="status">404</p>
    <h1>{display.notFound.heading}</h1>
    <p class="subheading">{display.notFound.subheading}</p>
    <a class="cta" href={homeHref}>{display.notFound.cta}</a>
  </main>
  <Footer locale={locale} />
</Layout>

<style>
  main.not-found {
    max-width: 36rem;
    margin: 0 auto;
    padding: 6rem 1.25rem 4rem;
    text-align: center;
  }

  .status {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-primary);
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .subheading {
    margin: 0 0 2.5rem;
    color: var(--color-muted);
    font-size: 1.0625rem;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.5rem;
    background: var(--color-primary);
    color: #fff;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: transform 120ms ease;
  }

  .cta:hover {
    transform: translateY(-1px);
  }
</style>
